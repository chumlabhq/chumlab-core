NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Google OAuth - required for /api/playground/* endpoints
# Get this from https://console.cloud.google.com/apis/credentials (OAuth 2.0 Web Client)
GOOGLE_CLIENT_ID=xxxxxxxx-xxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# Set to "false" to skip ID-token verification (DEV ONLY - never disable in production)
GOOGLE_OAUTH_VERIFY=true

CORS_ORIGIN=*
