NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Google OAuth (server-side flow)
# Authorized redirect URI in Cloud Console must include {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxx-xxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# JWT for HTTP-only auth cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-long-random-string

# Where the SPA lives - used as default fallbackUrl for OAuth callback
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# CORS - comma-separated origins (no trailing slash). credentials:include requires explicit origins.
CORS_ORIGIN=http://localhost:5173

# Playground access - comma-separated admin emails. Access is open to every
# signed-in user by default; set PLAYGROUND_INVITE_ONLY=true to require an invite.
ADMIN_EMAILS=you@example.com
PLAYGROUND_INVITE_ONLY=false

# Quotas - per user per UTC day, all users per UTC day (spend backstop),
# and a per-user short-term burst throttle.
PLAYGROUND_DAILY_LIMIT=20
PLAYGROUND_GLOBAL_DAILY_LIMIT=150
PLAYGROUND_BURST_PER_MINUTE=10

# Anthropic - main generation model for the pipeline, plus the small fast models
# the complexity router and follow-up classifier use.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5
ANTHROPIC_CLASSIFY_MODEL=claude-haiku-4-5
# Ceiling for the tier-scaled output budget (full builds retry once at 2x on truncation)
ANTHROPIC_MAX_OUTPUT_TOKENS=64000
# Per-call LLM timeout in ms - a hung call aborts cleanly instead of hanging the stream
ANTHROPIC_TIMEOUT_MS=90000
# Optional: path to the @chumlab/ui type definitions the type gate checks against
# CHUMLAB_UI_DIR=
