NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Google OAuth (server-side flow)
# Authorized redirect URI in Cloud Console must include {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxx-xxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# JWT for HTTP-only auth cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-long-random-string

# Where the SPA lives - used as default fallbackUrl for OAuth callback
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# CORS - comma-separated origins (no trailing slash). credentials:include requires explicit origins.
CORS_ORIGIN=http://localhost:5173
